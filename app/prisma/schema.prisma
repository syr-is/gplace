datasource db {
    provider = "postgresql"
    url = env("DATABASE_URL")
}

generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native"]
    previewFeatures = ["extendedWhereUnique","fieldReference"]
}

enum Role {
    USER
    ADMIN
}

/// @@allow('read', true)
model User {
    createdAt DateTime @default(now())
    editedAt DateTime @default(now())
    id String @id() @unique()
    syrInstanceUrl String
    delegatePublicKey String
    role Role @default(USER)
    totalPixelsChanged Int @default(0)
    pixels Pixel[]
    sessions Session[]
}

model Session {
    createdAt DateTime @default(now())
    editedAt DateTime @default(now())
    id String @id()
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId String
    did String
    syrInstanceUrl String
    platformToken String
    delegatePublicKey String
    tokenExpiresAt DateTime

    @@index([userId])
    @@index([tokenExpiresAt])
}

/// @@allow('read', true)
/// @@allow('create,update,delete', auth().role == 'ADMIN')
model Board {
    createdAt DateTime @default(now())
    editedAt DateTime @default(now())
    id String @id() @unique() @default(cuid())
    /// @length(3, 20)
    name String @unique()
    /// @length(3, 100)
    description String?
    dimX Int
    dimY Int
    /// @length(7, 7)
    color String @default("#ffffff")
    pixels Pixel[]
}

/// @@allow('read,update', true)
/// @@allow('create,delete', auth().role == 'ADMIN')
model Pixel {
    createdAt DateTime @default(now())
    editedAt DateTime @default(now())
    board Board @relation(fields: [boardId], references: [id])
    boardId String
    x Int
    y Int
    /// @length(7, 7)
    color String @default("#ffffff")
    user User @relation(fields: [userId], references: [id])
    userId String

    @@unique([boardId, x, y], name: "PixelIdentifier")
}